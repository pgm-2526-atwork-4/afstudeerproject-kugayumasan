{
  "expo": {
    "name": "vesalius",
    "slug": "vesalius",
    "scheme": "vesalius",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vesalius.ai"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "vesalius.ai",
      "permissions": ["RECORD_AUDIO", "android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-speech-recognition",
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f7dffd93-49c0-40a4-831c-217a8176ff9c"
      }
    }
  }
}
